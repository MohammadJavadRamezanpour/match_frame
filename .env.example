# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# New-style key names (preferred). Supabase calls these "publishable" and "secret"
# in the dashboard under Project Settings → API keys.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
# Legacy names — still accepted if you only have the older JWT-style keys:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe Price ID (one photo test = one purchase of this Price).
# Create it once in Stripe → Products → Add product → save the price id (price_...).
STRIPE_PRICE_ID=price_...

# --- OpenAI (Vision) ---
OPENAI_API_KEY=sk-...
OPENAI_VISION_MODEL=gpt-4o

# --- Resend (Email) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=MatchFrame <hello@matchframe.app>

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Used by /api/cron/process to authenticate scheduled runs.
CRON_SECRET=replace-with-long-random-string
